# Optional AI insight narration (OpenAI-compatible API). Leave empty to use rule-based fallback.
# OpenAI example:
# SINAD_AI_BASE_URL=https://api.openai.com/v1
# SINAD_AI_MODEL=gpt-4o-mini
# MiMo example:
# SINAD_AI_BASE_URL=https://api.xiaomimimo.com/v1
# SINAD_AI_MODEL=mimo-v2.5-pro
SINAD_AI_API_KEY=
SINAD_AI_BASE_URL=https://api.openai.com/v1
SINAD_AI_MODEL=gpt-4o-mini
# Reasoning models such as MiMo need more completion budget/time than small OpenAI models.
SINAD_AI_MAX_TOKENS=768
SINAD_AI_TIMEOUT_MS=18000
